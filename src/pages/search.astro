---
import Base from '../layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Base title="Search">
  <div class="home-header">
    <h1 id="search-heading">Search</h1>
  </div>

  <div id="search-results">
    <p class="text-muted">Loading…</p>
  </div>
</Base>

<script is:inline define:vars={{ base }}>
  const params = new URLSearchParams(window.location.search)
  const query = params.get('q') || ''

  const heading = document.getElementById('search-heading')
  const resultsEl = document.getElementById('search-results')

  // Pre-fill the header search input with the current query
  const headerInput = document.querySelector('.header-search input')
  if (headerInput && query) headerInput.value = query

  async function runSearch(q) {
    if (!q.trim()) {
      heading.textContent = 'Search'
      resultsEl.innerHTML = '<p class="text-muted">Enter a search term above.</p>'
      return
    }

    heading.textContent = `"${q}"`
    resultsEl.innerHTML = '<p class="text-muted">Searching…</p>'

    try {
      const pagefind = await import(base + '/pagefind/pagefind.js')
      await pagefind.init()
      const { results } = await pagefind.search(q)

      if (results.length === 0) {
        resultsEl.innerHTML = '<p class="text-muted">No pages found.</p>'
        return
      }

      const data = await Promise.all(results.map(r => r.data()))

      const countLine = `<p class="text-muted" style="margin-bottom:20px">${results.length} result${results.length !== 1 ? 's' : ''}</p>`

      const cards = data.map(d => `
          <a href="${d.url}" class="search-result">
            <div class="result-title">${d.meta?.title || d.url}</div>
            ${d.excerpt ? `<div class="result-excerpt">${d.excerpt}</div>` : ''}
          </a>`
      ).join('')

      resultsEl.innerHTML = countLine + cards
    } catch (err) {
      resultsEl.innerHTML = '<p class="text-muted">Search index not available.</p>'
    }
  }

  runSearch(query)
</script>
