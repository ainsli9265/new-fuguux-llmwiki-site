---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

export async function getStaticPaths() {
  const entries = await getCollection('wiki')
  const tagMap = new Map<string, typeof entries>()

  for (const entry of entries) {
    for (const tag of entry.data.tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, [])
      tagMap.get(tag)!.push(entry)
    }
  }

  return [...tagMap.entries()].map(([tag, pages]) => ({
    params: { tag },
    props: { tag, pages: pages.sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id)) },
  }))
}

const { tag, pages } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const typeOrder = ['concept', 'entity', 'source', 'query', 'comparison', 'synthesis']
const byType = typeOrder.reduce(
  (acc, t) => {
    acc[t] = pages.filter(e => (e.data.type ?? 'other') === t)
    return acc
  },
  {} as Record<string, typeof pages>
)
const typeLabels: Record<string, string> = {
  concept: 'Concepts', entity: 'Entities', source: 'Sources',
  query: 'Queries', comparison: 'Comparisons', synthesis: 'Synthesis',
}
---

<Base title={`#${tag}`}>
  <div class="home-header">
    <h1>#{tag}</h1>
    <p>{pages.length} page{pages.length !== 1 ? 's' : ''} tagged with this</p>
  </div>

  {typeOrder.map(type => byType[type]?.length > 0 && (
    <section class="type-section">
      <h2>{typeLabels[type]}</h2>
      <div class="entry-grid">
        {byType[type].map(entry => (
          <a href={`${base}/wiki/${entry.id}/`} class="entry-link">
            <span class="entry-title">{entry.data.title ?? entry.id}</span>
            {entry.data.tags.filter(t => t !== tag).length > 0 && (
              <span class="entry-tags">
                {entry.data.tags.filter(t => t !== tag).slice(0, 4).join(' · ')}
              </span>
            )}
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>
